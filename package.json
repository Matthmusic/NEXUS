{
  "name": "nexus",
  "description": "NEXUS - base de prix par references electriques (Electron + React).",
  "author": "Matthieu Maurel",
  "private": true,
  "version": "0.1.2",
  "type": "commonjs",
  "main": "electron/main.cjs",
  "build": {
    "appId": "com.matthmusic.nexus",
    "productName": "NEXUS",
    "icon": "electron/nexus.ico",
    "directories": {
      "output": "dist",
      "buildResources": "electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "NEXUS-${version}-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Matthmusic",
        "repo": "NEXUS"
      }
    ]
  },
  "scripts": {
    "dev": "vite --port 5601 --strictPort",
    "build": "tsc -b && vite build",
    "build:electron": "npm run build && electron-builder build --win",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron": "cross-env VITE_DEV_SERVER_URL=http://localhost:5601 electron .",
    "electron:dev": "concurrently -k \"npm run dev\" \"npm run electron\"",
    "start": "npm run electron"
  },
  "dependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron-updater": "^6.8.3",
    "fuse.js": "^7.0.0",
    "lucide-react": "^0.562.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^39.2.7",
    "electron-builder": "^26.7.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4"
  }
}
